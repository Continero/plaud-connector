# Option 1: Bearer token (for Google SSO users)
# Grab from browser DevTools → Network → any api.plaud.ai request → Authorization header
PLAUD_TOKEN=bearer eyJ...

# Option 2: Email/password
# PLAUD_EMAIL=your@email.com
# PLAUD_PASSWORD=your_password

# Optional: for EU accounts
# PLAUD_API_BASE=https://api-euc1.plaud.ai
